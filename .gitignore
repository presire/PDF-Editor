# ============================================
# AWS 認証情報・機密情報
# ============================================
# 通常は Webルート外に配置しているが、誤って配置された場合の防御
credentials
config
.aws/
*.pem
*.key
*.p12
.env
.env.*
!.env.example

# ============================================
# 診断・デバッグ用スクリプト
# ============================================
# 運用安定後に削除する想定のファイル
diagnose.php

# ============================================
# ローカル設定の上書き
# ============================================
config.local.php
.htaccess.local

# ============================================
# ログ・一時ファイル
# ============================================
*.log
logs/
tmp/
temp/
cache/
sessions/

# ============================================
# Composer（将来導入時用）
# ============================================
/vendor/
composer.phar

# ============================================
# Node.js（将来導入時用）
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================
# OS固有ファイル
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# エディタ・IDE
# ============================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*.swn
*~
.project
.buildpath
.settings/
nbproject/

# ============================================
# バックアップ・一時ファイル
# ============================================
*.bak
*.backup
*.old
*.orig
*.tmp
*.save
*~

# ============================================
# テスト・カバレッジ
# ============================================
/coverage/
.phpunit.result.cache
phpunit.xml
.phpcs-cache

# ============================================
# qpdf プラットフォーム依存バイナリ
# ============================================
# qpdf/bin と qpdf/lib はサーバ環境ごとに用意するためコミットしない
# 必要なら下記をコメントアウトしてコミット対象に含める
qpdf/bin/
qpdf/lib/

# ============================================
# アップロードされたPDF・処理済みPDF
# ============================================
uploads/
output/
*.pdf
# ライブラリやアセット内のPDFは除外しない場合のために allow も用意
!js/*.pdf
!assets/*.pdf
